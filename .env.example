# Firebase web config — copy this file to ".env" and fill in your project's values.
# Find these in Firebase Console → Project settings → General → "Your apps" → Web app.
# These are NOT secrets (Firebase ships them in client apps); .env just keeps
# project-specific values out of the committed source.
EXPO_PUBLIC_FIREBASE_API_KEY=your-web-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id
